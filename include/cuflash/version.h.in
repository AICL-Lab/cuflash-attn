#pragma once

// CuFlash-Attn version header (auto-generated by CMake)

#define CUFLASH_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define CUFLASH_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define CUFLASH_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define CUFLASH_VERSION "@PROJECT_VERSION@"

// Numeric version code for comparisons: MAJOR * 10000 + MINOR * 100 + PATCH
#define CUFLASH_VERSION_CODE \
    (CUFLASH_VERSION_MAJOR * 10000 + CUFLASH_VERSION_MINOR * 100 + CUFLASH_VERSION_PATCH)
