# clangd Language Server Configuration for CuFlash-Attn
# Preferred workflow:
# 1. Run `cmake --preset release` to generate build/release/compile_commands.json.
# 2. If CUDA Toolkit + nvcc are available, clangd gets full project-aware diagnostics.
# 3. The extra flags below keep clangd useful on partially configured machines, but
#    compile_commands.json remains the source of truth and `.cu` diagnostics may still
#    be incomplete without a full CUDA toolchain.

CompileFlags:
  # Point to the compile_commands.json generated by CMake
  CompilationDatabase: build/release

  # Add CUDA language mode and common include paths so clangd can still provide
  # partial navigation/completion on non-CUDA machines.
  Add:
    - -I./include
    - -I./src/kernels
    - --cuda-gpu-arch=sm_86
    - -x
    - cuda

Diagnostics:
  # Suppress CUDA-specific warnings that clangd can't resolve
  Suppress:
    - cuda_device_builtin_vector_types
    - unknown_pragma
  UnusedIncludes: Strict
  ClangTidy:
    Add:
      - bugprone-*
      - modernize-use-nullptr
      - modernize-use-override
      - performance-*
    Remove:
      - bugprone-narrowing-conversions
      - modernize-use-trailing-return-type
      - cppcoreguidelines-pro-type-reinterpret-cast
      - cppcoreguidelines-pro-bounds-pointer-arithmetic

InlayHints:
  Enabled: true
  ParameterNames: true
  DeducedTypes: true

Hover:
  ShowAKA: true

Index:
  Background: Build
