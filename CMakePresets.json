{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 18,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default (Debug)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTS": "ON",
                "BUILD_SHARED_LIBS": "ON"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTS": "ON",
                "BUILD_SHARED_LIBS": "ON"
            }
        },
        {
            "name": "release-fast-math",
            "displayName": "Release with fast math",
            "inherits": "release",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "ENABLE_FAST_MATH": "ON"
            }
        },
        {
            "name": "minimal",
            "displayName": "Minimal (no tests)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTS": "OFF",
                "BUILD_SHARED_LIBS": "OFF",
                "BUILD_EXAMPLES": "OFF"
            }
        },
        {
            "name": "debug-asan",
            "displayName": "Debug with AddressSanitizer",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTS": "ON",
                "BUILD_SHARED_LIBS": "ON",
                "ENABLE_ASAN": "ON"
            }
        },
        {
            "name": "all-architectures",
            "displayName": "Release (All GPU Architectures)",
            "inherits": "release",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_CUDA_ARCHITECTURES": "70;75;80;86;89;90"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "release-fast-math",
            "configurePreset": "release-fast-math"
        },
        {
            "name": "minimal",
            "configurePreset": "minimal"
        },
        {
            "name": "debug-asan",
            "configurePreset": "debug-asan"
        },
        {
            "name": "all-architectures",
            "configurePreset": "all-architectures"
        }
    ],
    "testPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "release",
            "configurePreset": "release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "debug-asan",
            "configurePreset": "debug-asan",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
